---
import FaqSection from "@/components/FaqSection.astro";
import HomePageContent from "@/components/HomePageContent.astro";
import LeadSection from "@/components/LeadSection.astro";
import LocalizedNavbar from "@/components/LocalizedNavbar.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import { homeContent } from "@/data/home-content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildHomeStructuredData } from "@/lib/structured-data";
import { getAbsoluteUrl, getAlternateLinks, getLocalizedPath } from "@/lib/routes";

const locale = "es";
const routeKey = "home";
const updatedAt = new Date();
const content = homeContent[locale];
const modifiedTime = updatedAt.toISOString();
---

<BaseLayout
  title={content.metaTitle}
  description={content.metaDescription}
  locale={locale}
  canonicalPath={getLocalizedPath(locale, routeKey)}
  alternateLinks={getAlternateLinks(routeKey)}
  xDefaultHref={getAbsoluteUrl(getLocalizedPath("ca", routeKey))}
  modifiedTime={modifiedTime}
  structuredData={buildHomeStructuredData({
    locale,
    metaTitle: content.metaTitle,
    metaDescription: content.metaDescription,
    faqItems: content.faqItems,
    modifiedTime,
  })}
>
  <LocalizedNavbar locale={locale} routeKey={routeKey} />
  <main>
    <HomePageContent locale={locale} updatedAt={updatedAt} />
    <LeadSection locale={locale} routeKey={routeKey} />
    <FaqSection
      locale={locale}
      title={content.faqTitle}
      items={content.faqItems}
      label="FAQ schema"
      note={content.freshnessLabel}
      updatedAt={updatedAt}
    />
  </main>
  <SiteFooter locale={locale} routeKey={routeKey} updatedAt={updatedAt} />
</BaseLayout>
