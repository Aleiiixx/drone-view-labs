---
import AboutSection from "@/components/AboutSection.astro";
import BenefitsSection from "@/components/BenefitsSection.astro";
import ContactSection from "@/components/ContactSection.astro";
import Footer from "@/components/Footer.astro";
import HeroSection from "@/components/HeroSection.astro";
import Navbar from "@/components/Navbar.astro";
import ProcessSection from "@/components/ProcessSection.astro";
import ProjectsSection from "@/components/ProjectsSection.astro";
import ServicesSection from "@/components/ServicesSection.astro";
import TechnologySection from "@/components/TechnologySection.astro";
import { getSiteUrl, siteConfig } from "@/data/site";
import { translations } from "@/data/translations";
import BaseLayout from "@/layouts/BaseLayout.astro";

const siteUrl = getSiteUrl();
const organizationId = siteUrl ? `${siteUrl}/#organization` : "#organization";
const websiteId = siteUrl ? `${siteUrl}/#website` : "#website";
const webpageId = siteUrl ? `${siteUrl}/#webpage` : "#webpage";
const currentUrl = siteUrl || "/";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": websiteId,
    url: currentUrl,
    name: siteConfig.name,
    inLanguage: "ca",
  },
  {
    "@context": "https://schema.org",
    "@type": siteConfig.business.type,
    "@id": organizationId,
    name: siteConfig.legalName,
    url: currentUrl,
    image: siteUrl ? `${siteUrl}/favicon.ico` : undefined,
    areaServed: {
      "@type": "AdministrativeArea",
      name: siteConfig.location.areaServed,
    },
    address: {
      "@type": "PostalAddress",
      addressLocality: siteConfig.location.locality,
      addressRegion: siteConfig.location.region,
      addressCountry: siteConfig.location.country,
    },
    serviceType: siteConfig.business.services,
    priceRange: siteConfig.business.priceRange,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": webpageId,
    url: currentUrl,
    name: translations.ca["meta.title"],
    description: translations.ca["meta.description"],
    inLanguage: "ca",
    isPartOf: { "@id": websiteId },
    about: { "@id": organizationId },
  },
].map((item) =>
  Object.fromEntries(Object.entries(item).filter(([, value]) => value !== undefined)),
);
---

<BaseLayout
  title={translations.ca["meta.title"]}
  description={translations.ca["meta.description"]}
  locale="ca"
  structuredData={structuredData}
>
  <Navbar />
  <main>
    <HeroSection />
    <ServicesSection />
    <TechnologySection />
    <BenefitsSection />
    <ProcessSection />
    <ProjectsSection />
    <AboutSection />
    <ContactSection />
  </main>
  <Footer />

  <script define:vars={{ translations }}>
    const supportedLocales = ["ca", "es", "en"];

    const detectLocale = () => {
      const languages = Array.isArray(navigator.languages) && navigator.languages.length
        ? navigator.languages
        : [navigator.language || "ca"];

      for (const language of languages) {
        const normalized = String(language).toLowerCase();
        if (normalized.startsWith("ca")) return "ca";
        if (normalized.startsWith("es")) return "es";
        if (normalized.startsWith("en")) return "en";
      }

      return "ca";
    };

    const locale = detectLocale();
    const messages = translations[locale] || translations.ca;

    const formatValue = (value, element) =>
      String(value).replace(/\{(\w+)\}/g, (_, key) => element?.dataset?.[key] ?? `{${key}}`);

    document.documentElement.lang = supportedLocales.includes(locale) ? locale : "ca";
    document.title = messages["meta.title"] || document.title;

    const description = document.querySelector("#site-description");
    if (description && messages["meta.description"]) {
      description.setAttribute("content", messages["meta.description"]);
    }

    const ogTitle = document.querySelector("#meta-og-title");
    if (ogTitle && messages["meta.title"]) {
      ogTitle.setAttribute("content", messages["meta.title"]);
    }

    const ogDescription = document.querySelector("#meta-og-description");
    if (ogDescription && messages["meta.description"]) {
      ogDescription.setAttribute("content", messages["meta.description"]);
    }

    const twitterTitle = document.querySelector("#meta-twitter-title");
    if (twitterTitle && messages["meta.title"]) {
      twitterTitle.setAttribute("content", messages["meta.title"]);
    }

    const twitterDescription = document.querySelector("#meta-twitter-description");
    if (twitterDescription && messages["meta.description"]) {
      twitterDescription.setAttribute("content", messages["meta.description"]);
    }

    document.querySelectorAll("[data-i18n]").forEach((element) => {
      const key = element.getAttribute("data-i18n");
      if (!key || !messages[key]) return;
      element.textContent = formatValue(messages[key], element);
    });

    document.querySelectorAll("[data-i18n-html]").forEach((element) => {
      const key = element.getAttribute("data-i18n-html");
      if (!key || !messages[key]) return;
      element.innerHTML = formatValue(messages[key], element);
    });

    document.querySelectorAll("[data-i18n-placeholder]").forEach((element) => {
      const key = element.getAttribute("data-i18n-placeholder");
      if (!key || !messages[key]) return;
      element.setAttribute("placeholder", formatValue(messages[key], element));
    });

    document.querySelectorAll("[data-i18n-alt]").forEach((element) => {
      const key = element.getAttribute("data-i18n-alt");
      if (!key || !messages[key]) return;
      element.setAttribute("alt", formatValue(messages[key], element));
    });

    document.querySelectorAll("[data-i18n-aria-label]").forEach((element) => {
      const key = element.getAttribute("data-i18n-aria-label");
      if (!key || !messages[key]) return;
      element.setAttribute("aria-label", formatValue(messages[key], element));
    });

    document.querySelectorAll("[data-i18n-success]").forEach((element) => {
      const key = element.getAttribute("data-i18n-success");
      if (!key || !messages[key]) return;
      element.dataset.successMessage = formatValue(messages[key], element);
    });

    document.querySelectorAll("[data-i18n-invalid]").forEach((element) => {
      const key = element.getAttribute("data-i18n-invalid");
      if (!key || !messages[key]) return;
      element.dataset.invalidMessage = formatValue(messages[key], element);
    });

    document.querySelectorAll("[data-i18n-error]").forEach((element) => {
      const key = element.getAttribute("data-i18n-error");
      if (!key || !messages[key]) return;
      element.textContent = formatValue(messages[key], element);
    });
  </script>
</BaseLayout>
