---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found | SERVIDRONE">
  <main class="flex min-h-screen items-center justify-center px-4">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-primary">404</p>
      <h1 class="mt-4 text-4xl font-bold text-foreground md:text-6xl">Page not found</h1>
      <p class="mx-auto mt-4 max-w-xl text-muted-foreground">
        The page you requested does not exist or has been moved.
      </p>
      <a href="/" class="btn btn-primary mt-8">Back to home</a>
    </div>
  </main>
</BaseLayout>
