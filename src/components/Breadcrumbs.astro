---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  separator?: string;
}

const { items, separator = "/" } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-xs text-muted-foreground sm:text-sm">
  <ol class="flex flex-wrap items-center gap-1.5 sm:gap-2">
    {
      items.map((item, index) => (
        <>
          <li>
            {item.href ? (
              <a href={item.href} class="transition-colors hover:text-primary">
                {item.label}
              </a>
            ) : (
              <span class="font-medium text-foreground">{item.label}</span>
            )}
          </li>
          {index < items.length - 1 && <li aria-hidden="true">{separator}</li>}
        </>
      ))
    }
  </ol>
</nav>
