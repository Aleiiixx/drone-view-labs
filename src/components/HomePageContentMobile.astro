---
import { Image } from "astro:assets";
import heroImage from "@/assets/hero-aerial.jpg";
import droneImage from "@/assets/matrice-400-l3.webp";
import terrainModel from "@/assets/terrain-model.jpg";
import { homeContent } from "@/data/home-content";
import { getLocalizedPath, type Locale } from "@/lib/routes";
import { Camera, Map, Sprout } from "lucide-react";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = homeContent[locale];

const copy = {
  ca: {
    searchIntent: "Serveis",
    authority: "Enfocament",
    deliverables: "Lliuraments",
    sectors: "Sectors",
    comparison: "Comparativa",
    outputs: "Lliuraments",
    fit: "Ideal per",
    drone: "Dron",
    traditional: "Tradicional",
  },
  es: {
    searchIntent: "Servicios",
    authority: "Enfoque",
    deliverables: "Entregables",
    sectors: "Sectores",
    comparison: "Comparativa",
    outputs: "Entregables",
    fit: "Ideal para",
    drone: "Dron",
    traditional: "Tradicional",
  },
  en: {
    searchIntent: "Services",
    authority: "Approach",
    deliverables: "Deliverables",
    sectors: "Sectors",
    comparison: "Comparison",
    outputs: "Deliverables",
    fit: "Best fit",
    drone: "Drone",
    traditional: "Traditional",
  },
}[locale];

const serviceIcons = {
  topography: Map,
  agriculture: Sprout,
  inspections: Camera,
} as const;
---

<div class="md:hidden">
  <section class="relative overflow-hidden bg-foreground">
    <div class="absolute inset-0">
      <Image
        src={heroImage}
        alt={content.title}
        format="webp"
        widths={[480, 768, 1024]}
        sizes="100vw"
        quality={56}
        loading="eager"
        fetchpriority="high"
        class="h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-foreground/70 via-foreground/84 to-foreground"></div>
    </div>

    <div class="container-narrow relative z-10 px-4 pb-12 pt-24">
      <span class="inline-flex rounded-full border border-primary-foreground/15 bg-primary-foreground/10 px-4 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-primary-foreground/80">
        {content.eyebrow}
      </span>
      <h1 class="mt-4 text-3xl font-extrabold leading-tight text-primary-foreground">{content.title}</h1>
      <p class="mt-4 text-base leading-7 text-primary-foreground/80">{content.description}</p>

      <div class="mt-7 grid gap-3">
        <a href={content.primaryCta.href} class="btn btn-lg btn-primary w-full">
          {content.primaryCta.label}
        </a>
        <a
          href="#services-mobile"
          class="btn btn-lg w-full border border-primary-foreground/25 bg-transparent text-primary-foreground hover:bg-primary-foreground/10"
        >
          {content.secondaryCta.label}
        </a>
      </div>

      <div class="mt-8 space-y-3">
        {
          content.trustPoints.map((item, index) => (
            <article class="rounded-[1.75rem] border border-primary-foreground/10 bg-primary-foreground/8 p-4 backdrop-blur-sm">
              <div class="flex items-start gap-3">
                <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-primary-foreground/12 text-sm font-semibold text-primary-foreground">
                  {index + 1}
                </span>
                <p class="text-sm leading-6 text-primary-foreground/78">{item}</p>
              </div>
            </article>
          ))
        }
      </div>

      <div class="mt-8 overflow-hidden rounded-[2rem] border border-primary-foreground/10 bg-primary-foreground/6 shadow-sm">
        <Image
          src={droneImage}
          alt={content.eyebrow}
          widths={[420, 680, 980]}
          sizes="100vw"
          quality={64}
          class="h-48 w-full object-cover object-[78%_center]"
        />
      </div>

      <article class="mt-5 rounded-[2rem] border border-primary-foreground/10 bg-primary-foreground/7 p-5 backdrop-blur-sm">
        <span class="text-xs font-semibold uppercase tracking-[0.24em] text-primary-foreground/60">{copy.authority}</span>
        <p class="mt-3 text-sm leading-6 text-primary-foreground/82">{content.intro}</p>
      </article>
    </div>
  </section>

  <section id="services-mobile" class="section-padding topo-lines bg-background">
    <div class="container-narrow">
      <span class="text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground">{copy.searchIntent}</span>
      <h2 class="mt-3 text-2xl font-bold text-foreground">{content.servicesTitle}</h2>
      <p class="mt-4 text-sm leading-6 text-muted-foreground">{content.servicesDescription}</p>

      <div class="mt-8 space-y-4">
        {
          content.serviceCards.map((service, index) => {
            const Icon = serviceIcons[service.routeKey];
            const href = getLocalizedPath(locale, service.routeKey);

            return (
              <article class="rounded-[2rem] border border-border bg-card p-5 shadow-sm">
                <div class="flex items-start justify-between gap-3">
                  <div class="flex items-center gap-3">
                    <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10">
                      <Icon className="h-6 w-6 text-primary" />
                    </div>
                    <h3 class="text-lg font-bold text-foreground">{service.title}</h3>
                  </div>
                  <span class="text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground">{index + 1}</span>
                </div>

                <p class="mt-4 text-sm leading-6 text-muted-foreground">{service.description}</p>

                <ul class="mt-4 space-y-2">
                  {service.bullets.map((item) => (
                    <li class="flex items-start gap-3 text-sm leading-6 text-foreground">
                      <span class="mt-2 h-1.5 w-1.5 rounded-full bg-accent"></span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>

                <a href={href} class="mt-5 inline-flex text-sm font-semibold text-primary transition-colors hover:text-primary/80">
                  {service.title}
                </a>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <section class="section-padding bg-card">
    <div class="container-narrow space-y-5">
      <div class="overflow-hidden rounded-[2rem] border border-border bg-background shadow-sm">
        <Image
          src={terrainModel}
          alt={content.deliverablesTitle}
          widths={[480, 760, 1080]}
          sizes="100vw"
          quality={62}
          class="h-48 w-full object-cover"
        />
      </div>

      <article class="rounded-[2rem] border border-border bg-background p-5 shadow-sm">
        <span class="text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground">{copy.authority}</span>
        <h2 class="mt-3 text-2xl font-bold text-foreground">{content.whyTitle}</h2>

        <div class="mt-5 space-y-3">
          {
            content.whyItems.map((item) => (
              <div class="rounded-3xl border border-border bg-card p-4">
                <p class="text-sm leading-6 text-foreground">{item}</p>
              </div>
            ))
          }
        </div>
      </article>
    </div>
  </section>

  <section class="section-padding bg-background">
    <div class="container-narrow">
      <span class="text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground">{copy.deliverables}</span>
      <h2 class="mt-3 text-2xl font-bold text-foreground">{content.deliverablesTitle}</h2>
      <p class="mt-4 text-sm leading-6 text-muted-foreground">{content.deliverablesDescription}</p>

      <div class="mt-8 space-y-4">
        {
          content.deliverablesRows.map((row) => (
            <article class="rounded-[2rem] border border-border bg-card p-5 shadow-sm">
              <p class="text-sm font-semibold text-foreground">{row.service}</p>
              <div class="mt-4 space-y-4">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground">{copy.outputs}</p>
                  <p class="mt-2 text-sm leading-6 text-foreground">{row.deliverables}</p>
                </div>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground">{copy.fit}</p>
                  <p class="mt-2 text-sm leading-6 text-foreground">{row.fit}</p>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-padding bg-card">
    <div class="container-narrow space-y-10">
      <div>
        <span class="text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground">{copy.sectors}</span>
        <h2 class="mt-3 text-2xl font-bold text-foreground">{content.sectorsTitle}</h2>

        <div class="mt-6 space-y-3">
          {
            content.sectors.map((item, index) => (
              <article class="rounded-[1.75rem] border border-border bg-background p-4 shadow-sm">
                <div class="flex items-start gap-3">
                  <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-semibold text-primary">
                    {index + 1}
                  </span>
                  <p class="text-sm leading-6 text-foreground">{item}</p>
                </div>
              </article>
            ))
          }
        </div>
      </div>

      <div>
        <span class="text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground">{copy.comparison}</span>
        <h2 class="mt-3 text-2xl font-bold text-foreground">{content.comparisonTitle}</h2>
        <p class="mt-4 text-sm leading-6 text-muted-foreground">{content.comparisonDescription}</p>

        <div class="mt-6 space-y-4">
          {
            content.comparisonRows.map((row) => (
              <article class="rounded-[2rem] border border-border bg-background p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-primary">{row.focus}</p>
                <div class="mt-4 space-y-3">
                  <div class="rounded-2xl bg-card p-4">
                    <p class="text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground">{copy.drone}</p>
                    <p class="mt-2 text-sm leading-6 text-foreground">{row.drone}</p>
                  </div>
                  <div class="rounded-2xl bg-card p-4">
                    <p class="text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground">{copy.traditional}</p>
                    <p class="mt-2 text-sm leading-6 text-foreground">{row.traditional}</p>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</div>
