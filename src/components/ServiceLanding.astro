---
import { Image } from "astro:assets";
import { CalendarDays, Camera, FileText, Layers3, Map, Plane, Search, ShieldCheck, Sprout, Target } from "lucide-react";
import modelImage from "@/assets/terrain-model.jpg";
import mappingImage from "@/assets/terrain-mapping.jpg";
import ndviImage from "@/assets/T50.webp";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import ServiceLandingMobile from "@/components/ServiceLandingMobile.astro";
import { uiContent } from "@/data/ui-content";
import { routeLabels, getLocalizedPath, type Locale, type RouteKey } from "@/lib/routes";
import type { ServicePageContent } from "@/data/content-types";

interface Props {
  locale: Locale;
  content: ServicePageContent;
}

const { locale, content } = Astro.props;
const ui = uiContent[locale];

const images: Record<Exclude<RouteKey, "home">, typeof modelImage> = {
  topography: modelImage,
  agriculture: ndviImage,
  inspections: mappingImage,
};

const processIcons = {
  topography: [Search, Plane, Layers3, FileText],
  agriculture: [Search, ShieldCheck, CalendarDays, Sprout],
  inspections: [Target, Plane, Camera, Map],
} as const;

const processIconSet = processIcons[content.routeKey];

const copy = {
  ca: {
    summary: "Resum",
    deliverables: "Lliuraments",
    fit: "Quan encaixa",
    process: "Procés",
  },
  es: {
    summary: "Resumen",
    deliverables: "Entregables",
    fit: "Cuándo encaja",
    process: "Proceso",
  },
  en: {
    summary: "Summary",
    deliverables: "Deliverables",
    fit: "Best fit",
    process: "Process",
  },
}[locale];
---

<ServiceLandingMobile locale={locale} content={content} />

<div class="hidden md:block">
<section class="section-padding bg-card pt-24 sm:pt-28">
  <div class="container-narrow">
    <Breadcrumbs
      items={[
        { label: routeLabels.home[locale], href: getLocalizedPath(locale, "home") },
        { label: routeLabels[content.routeKey][locale] },
      ]}
      separator={ui.breadcrumbSeparator}
    />

    <div class="mt-6 grid items-center gap-8 sm:mt-8 sm:gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(360px,0.9fr)]">
      <div>
        <span class="inline-flex rounded-full border border-primary/20 bg-primary/10 px-4 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-primary sm:text-sm">
          {content.heroEyebrow}
        </span>
        <h1 class="mt-4 text-3xl font-bold leading-tight text-foreground sm:mt-5 sm:text-4xl md:text-6xl">
          {content.heroTitle}
        </h1>
        <p class="mt-4 max-w-2xl text-base text-muted-foreground sm:mt-5 sm:text-lg">{content.heroDescription}</p>

        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a href={content.primaryCta.href} class="btn btn-lg btn-primary w-full sm:w-auto">
            {content.primaryCta.label}
          </a>
          <a href={content.secondaryCta.href} class="btn btn-lg w-full border border-border bg-background text-foreground hover:border-primary/40 sm:w-auto">
            {content.secondaryCta.label}
          </a>
        </div>
      </div>

      <div class="rounded-3xl border border-border bg-background p-5 shadow-sm sm:p-6">
        <div class="overflow-hidden rounded-2xl">
          <Image
            src={images[content.routeKey]}
            alt={content.heroTitle}
            widths={[420, 720, 1080]}
            sizes="(min-width: 1024px) 40vw, 100vw"
            quality={64}
            class="h-52 w-full object-cover sm:h-64"
          />
        </div>
        <ul class="mt-6 space-y-3">
          {content.heroBullets.map((item) => (
            <li class="flex items-start gap-3 rounded-2xl border border-border bg-card p-3.5 text-sm leading-6 text-foreground sm:p-4">
              <span class="mt-2 h-1.5 w-1.5 rounded-full bg-accent"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<section class="section-padding topo-lines bg-background">
  <div class="container-narrow grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.95fr)]">
    <div>
      <span class="text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground sm:text-sm">{copy.summary}</span>
      <h2 class="mt-3 text-2xl font-bold text-foreground sm:text-3xl md:text-4xl">{content.overviewTitle}</h2>
      <div class="mt-6 space-y-4 text-base leading-7 text-muted-foreground">
        {content.overviewParagraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>

    <div class="rounded-3xl border border-border bg-card p-5 shadow-sm sm:p-6">
      <span class="text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground sm:text-sm">{copy.deliverables}</span>
      <h2 class="mt-3 text-xl font-bold text-foreground sm:text-2xl">{content.deliverablesTitle}</h2>
      <ul class="mt-6 space-y-3">
        {content.deliverables.map((item) => (
          <li class="flex items-start gap-3 rounded-2xl bg-background p-3.5 text-sm leading-6 text-foreground sm:p-4">
            <span class="mt-2 h-1.5 w-1.5 rounded-full bg-accent"></span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<section class="section-padding bg-card">
  <div class="container-narrow space-y-12">
    <div>
      <span class="text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground sm:text-sm">{copy.fit}</span>
      <h2 class="mt-3 text-2xl font-bold text-foreground sm:text-3xl md:text-4xl">{content.fitTitle}</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {content.fitItems.map((item) => (
          <div class="h-full rounded-3xl border border-border bg-background p-4 text-sm leading-6 text-foreground sm:p-5">
            {item}
          </div>
        ))}
      </div>
    </div>

    <div class="border-t border-border pt-10 sm:pt-12">
      <span class="text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground sm:text-sm">{copy.process}</span>
      <h2 class="mt-3 text-2xl font-bold text-foreground sm:text-3xl md:text-4xl">{content.processTitle}</h2>
      <div class="relative mt-7 w-full sm:mt-8">
        <div class="absolute bottom-5 left-5 top-5 w-px bg-border lg:bottom-auto lg:left-[12.5%] lg:right-[12.5%] lg:top-7 lg:h-px lg:w-auto"></div>
        {
          <div class="space-y-5 lg:grid lg:grid-cols-4 lg:gap-5 lg:space-y-0">
            {content.processSteps.map((step, index) => {
            const StepIcon = processIconSet[index] ?? FileText;
            const stepNumber = String(index + 1);

            return (
              <div class="relative pl-14 lg:pl-0 lg:pt-16">
                <div class="absolute left-0 top-0.5 z-10 flex h-10 w-10 items-center justify-center rounded-full border-4 border-card bg-primary text-primary-foreground shadow-sm lg:left-1/2 lg:top-0 lg:h-12 lg:w-12 lg:-translate-x-1/2">
                  <span class="text-sm font-bold tracking-[0.2em]">{stepNumber}</span>
                </div>
                <div class="absolute left-10 top-5 h-px w-4 bg-border lg:hidden"></div>

                <article class="flex h-full flex-col rounded-3xl border border-border bg-background p-4 shadow-sm sm:p-5">
                  <div class="flex items-start gap-3 sm:gap-4">
                    <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-2xl bg-primary/10 sm:h-12 sm:w-12">
                      <StepIcon className="h-5 w-5 text-primary" />
                    </div>
                    <div class="min-w-0">
                      <h3 class="text-lg font-bold text-foreground sm:text-xl">{step.title}</h3>
                    </div>
                  </div>
                  <p class="mt-3 text-sm leading-6 text-muted-foreground">{step.description}</p>
                </article>
              </div>
            );
          })}
          </div>
        }
      </div>
    </div>
  </div>
</section>
</div>
