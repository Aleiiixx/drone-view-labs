---
import { Mail, MapPin, Phone } from "lucide-react";
import { siteConfig } from "@/data/site";
import { uiContent } from "@/data/ui-content";
import { routeLabels, serviceRouteKeys, type Locale, type RouteKey } from "@/lib/routes";

interface Props {
  locale: Locale;
  routeKey: RouteKey;
}

const { locale, routeKey } = Astro.props;
const ui = uiContent[locale];
const selectedService = routeKey === "home" ? "" : routeLabels[routeKey][locale];
const contactItems = [
  {
    label: ui.contactEmail,
    value: siteConfig.business.email,
    href: `mailto:${siteConfig.business.email}`,
    icon: Mail,
  },
  {
    label: ui.contactPhone,
    value: siteConfig.business.telephone,
    href: `tel:${siteConfig.business.telephone.replace(/\s+/g, "")}`,
    icon: Phone,
  },
  {
    label: ui.contactArea,
    value: ui.contactAreaValue,
    href: null,
    icon: MapPin,
  },
];
const formPanels = {
  ca: {
    placeholderTitle: "Selecciona un servei per veure els camps específics",
    placeholderDescription:
      "Afegirem només les dades que realment necessitem per valorar el treball i respondre amb més context.",
    topography: {
      key: routeLabels.topography.ca,
      title: "Dades per a topografia amb dron",
      description: "Ens ajuda a dimensionar el treball i el tipus de lliurament que necessites.",
      fields: [
        {
          name: "topographyArea",
          label: "Superfície aproximada",
          placeholder: "Ex. 12 ha o 300 x 200 m",
          type: "text",
        },
        {
          name: "topographyDeliverable",
          label: "Què necessites rebre",
          placeholder: "Ex. ortofoto, corbes de nivell o model 3D",
          type: "text",
        },
        {
          name: "topographyDate",
          label: "Data orientativa",
          placeholder: "",
          type: "date",
        },
      ],
    },
    agriculture: {
      key: routeLabels.agriculture.ca,
      title: "Dades per a aplicació agrícola",
      description: "Aquí sí que necessitem alguns camps concrets per valorar la viabilitat.",
      fields: [
        {
          name: "agricultureProduct",
          label: "Fitosanitari o producte a aplicar",
          placeholder: "Ex. coure, bioestimulant o producte fitosanitari",
          type: "text",
        },
        {
          name: "agricultureHectares",
          label: "Hectàrees a tractar",
          placeholder: "Ex. 6 ha",
          type: "text",
        },
        {
          name: "agricultureDate",
          label: "Data orientativa",
          placeholder: "",
          type: "date",
        },
      ],
    },
    inspections: {
      key: routeLabels.inspections.ca,
      title: "Dades per a inspecció aèria",
      description: "Amb això podem entendre millor què s'ha de revisar i amb quin objectiu.",
      fields: [
        {
          name: "inspectionAsset",
          label: "Actiu o element a revisar",
          placeholder: "Ex. coberta, plaques solars, finca o nau",
          type: "text",
        },
        {
          name: "inspectionGoal",
          label: "Objectiu de la inspecció",
          placeholder: "Ex. manteniment, incidència o documentació visual",
          type: "text",
        },
        {
          name: "inspectionDate",
          label: "Data orientativa",
          placeholder: "",
          type: "date",
        },
      ],
    },
  },
  es: {
    placeholderTitle: "Selecciona un servicio para ver los campos específicos",
    placeholderDescription:
      "Mostraremos solo los datos que realmente necesitamos para valorar el trabajo y responder con más contexto.",
    topography: {
      key: routeLabels.topography.es,
      title: "Datos para topografía con dron",
      description: "Nos ayuda a dimensionar el trabajo y el tipo de entregable que necesitas.",
      fields: [
        {
          name: "topographyArea",
          label: "Superficie aproximada",
          placeholder: "Ej. 12 ha o 300 x 200 m",
          type: "text",
        },
        {
          name: "topographyDeliverable",
          label: "Qué necesitas recibir",
          placeholder: "Ej. ortofoto, curvas de nivel o modelo 3D",
          type: "text",
        },
        {
          name: "topographyDate",
          label: "Fecha orientativa",
          placeholder: "",
          type: "date",
        },
      ],
    },
    agriculture: {
      key: routeLabels.agriculture.es,
      title: "Datos para aplicación agrícola",
      description: "Aquí sí necesitamos algunos campos concretos para valorar la viabilidad.",
      fields: [
        {
          name: "agricultureProduct",
          label: "Fitosanitario o producto a aplicar",
          placeholder: "Ej. cobre, bioestimulante o producto fitosanitario",
          type: "text",
        },
        {
          name: "agricultureHectares",
          label: "Hectáreas a tratar",
          placeholder: "Ej. 6 ha",
          type: "text",
        },
        {
          name: "agricultureDate",
          label: "Fecha orientativa",
          placeholder: "",
          type: "date",
        },
      ],
    },
    inspections: {
      key: routeLabels.inspections.es,
      title: "Datos para inspección aérea",
      description: "Con esto podemos entender mejor qué hay que revisar y con qué objetivo.",
      fields: [
        {
          name: "inspectionAsset",
          label: "Activo o elemento a revisar",
          placeholder: "Ej. cubierta, placas solares, finca o nave",
          type: "text",
        },
        {
          name: "inspectionGoal",
          label: "Objetivo de la inspección",
          placeholder: "Ej. mantenimiento, incidencia o documentación visual",
          type: "text",
        },
        {
          name: "inspectionDate",
          label: "Fecha orientativa",
          placeholder: "",
          type: "date",
        },
      ],
    },
  },
  en: {
    placeholderTitle: "Select a service to see the specific fields",
    placeholderDescription:
      "We will only ask for the details that help qualify the job properly and answer with more context.",
    topography: {
      key: routeLabels.topography.en,
      title: "Details for drone surveying",
      description: "This helps size the work and understand the deliverable you need.",
      fields: [
        {
          name: "topographyArea",
          label: "Approximate area",
          placeholder: "E.g. 12 ha or 300 x 200 m",
          type: "text",
        },
        {
          name: "topographyDeliverable",
          label: "Requested deliverable",
          placeholder: "E.g. orthomosaic, contour lines or 3D model",
          type: "text",
        },
        {
          name: "topographyDate",
          label: "Target date",
          placeholder: "",
          type: "date",
        },
      ],
    },
    agriculture: {
      key: routeLabels.agriculture.en,
      title: "Details for agricultural applications",
      description: "These are the core fields needed to assess feasibility.",
      fields: [
        {
          name: "agricultureProduct",
          label: "Phytosanitary or product to apply",
          placeholder: "E.g. copper, biostimulant or crop protection product",
          type: "text",
        },
        {
          name: "agricultureHectares",
          label: "Hectares to treat",
          placeholder: "E.g. 6 ha",
          type: "text",
        },
        {
          name: "agricultureDate",
          label: "Target date",
          placeholder: "",
          type: "date",
        },
      ],
    },
    inspections: {
      key: routeLabels.inspections.en,
      title: "Details for aerial inspections",
      description: "This gives enough context to understand what must be reviewed and why.",
      fields: [
        {
          name: "inspectionAsset",
          label: "Asset or element to inspect",
          placeholder: "E.g. roof, solar panels, property or facility",
          type: "text",
        },
        {
          name: "inspectionGoal",
          label: "Inspection goal",
          placeholder: "E.g. maintenance, issue review or visual documentation",
          type: "text",
        },
        {
          name: "inspectionDate",
          label: "Target date",
          placeholder: "",
          type: "date",
        },
      ],
    },
  },
}[locale];
---

<section id="contact" class="section-padding topo-lines bg-background">
  <div class="container-narrow">
    <div class="space-y-6">
      <div class="grid gap-4 md:grid-cols-3">
        {
          contactItems.map((item) => {
            const Icon = item.icon;

            return (
              <article class="flex items-start gap-4 rounded-3xl border border-border bg-card p-4 shadow-sm sm:items-center sm:p-5">
                <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-2xl bg-primary/10">
                  <Icon className="h-5 w-5 text-primary" />
                </div>
                <div class="min-w-0 flex-1">
                  {
                    item.href ? (
                      <a href={item.href} class="block text-base font-semibold leading-6 text-foreground break-all md:break-normal">
                        <span class="sr-only">{item.label}: </span>
                        {item.value}
                      </a>
                    ) : (
                      <p class="text-base font-semibold leading-6 text-foreground">
                        <span class="sr-only">{item.label}: </span>
                        {item.value}
                      </p>
                    )
                  }
                </div>
              </article>
            );
          })
        }
      </div>

      <div class="rounded-3xl border border-border bg-card p-5 shadow-md sm:p-6 md:p-8">
        <span class="text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground sm:text-sm">{ui.formEyebrow}</span>
        <h2 class="mt-3 text-2xl font-bold text-foreground sm:text-3xl md:text-4xl">{ui.formTitle}</h2>
        <p class="mt-4 max-w-2xl text-muted-foreground">{ui.formDescription}</p>

        <form
          class="mt-8 space-y-5"
          name="contact"
          method="POST"
          action="/"
          data-netlify="true"
          netlify-honeypot="bot-field"
          data-service-form
        >
          <input type="hidden" name="form-name" value="contact" />
          <input type="hidden" name="pageSource" value={routeLabels[routeKey][locale]} />

          <p class="hidden">
            <label>
              Don't fill this out if you're human:
              <input name="bot-field" />
            </label>
          </p>

          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="name" class="field-label">{ui.formName}</label>
              <input id="name" name="name" class="input-field" maxlength="100" required />
            </div>
            <div>
              <label for="email" class="field-label">{ui.formEmail}</label>
              <input id="email" name="email" type="email" class="input-field" maxlength="255" required />
            </div>
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="phone" class="field-label">{ui.formPhone}</label>
              <input id="phone" name="phone" type="tel" class="input-field" maxlength="20" />
            </div>
            <div>
              <label for="service" class="field-label">{ui.formService}</label>
              <select id="service" name="service" class="input-field" required data-service-select>
                <option value="" selected={selectedService === ""} disabled>{ui.formServicePlaceholder}</option>
                {
                  serviceRouteKeys.map((serviceKey) => (
                    <option value={routeLabels[serviceKey][locale]} selected={selectedService === routeLabels[serviceKey][locale]}>
                      {routeLabels[serviceKey][locale]}
                    </option>
                  ))
                }
              </select>
            </div>
          </div>

          <div>
            <label for="location" class="field-label">{ui.formLocation}</label>
            <input id="location" name="location" class="input-field" placeholder={ui.formLocationPlaceholder} maxlength="120" />
          </div>

          <div class="rounded-3xl border border-border bg-background p-4 sm:p-5" data-service-panel-shell>
            <div data-service-placeholder>
              <h3 class="text-lg font-semibold text-foreground">{formPanels.placeholderTitle}</h3>
              <p class="mt-2 text-sm leading-6 text-muted-foreground">{formPanels.placeholderDescription}</p>
            </div>

            {(["topography", "agriculture", "inspections"] as const).map((panelKey) => {
              const panel = formPanels[panelKey];

              return (
                <div class="hidden" data-service-panel={panel.key}>
                  <h3 class="text-lg font-semibold text-foreground">{panel.title}</h3>
                  <p class="mt-2 text-sm leading-6 text-muted-foreground">{panel.description}</p>
                  <div class="mt-5 grid gap-5 sm:grid-cols-3">
                    {panel.fields.map((field) => (
                      <div>
                        <label for={field.name} class="field-label">{field.label}</label>
                        <input
                          id={field.name}
                          name={field.name}
                          type={field.type}
                          class="input-field"
                          placeholder={field.placeholder}
                          data-service-field={panel.key}
                          disabled
                        />
                      </div>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>

          <div>
            <label for="message" class="field-label">{ui.formMessage}</label>
            <textarea
              id="message"
              name="message"
              class="textarea-field"
              rows="7"
              maxlength="1200"
              placeholder={ui.formMessagePlaceholder}
              required
            ></textarea>
          </div>

          <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <p class="max-w-xl text-sm text-muted-foreground">{ui.formPrivacy}</p>
            <button type="submit" class="btn btn-lg btn-primary w-full sm:w-auto">{ui.formSubmit}</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector("[data-service-form]");

  if (form instanceof HTMLFormElement) {
    const serviceSelect = form.querySelector("[data-service-select]");
    const placeholder = form.querySelector("[data-service-placeholder]");
    const panels = Array.from(form.querySelectorAll("[data-service-panel]"));
    const fields = Array.from(form.querySelectorAll("[data-service-field]"));

    const updateServicePanel = () => {
      if (!(serviceSelect instanceof HTMLSelectElement)) return;

      const selectedValue = serviceSelect.value;

      panels.forEach((panel) => {
        if (!(panel instanceof HTMLElement)) return;
        const isActive = panel.dataset.servicePanel === selectedValue;
        panel.classList.toggle("hidden", !isActive);
      });

      if (placeholder instanceof HTMLElement) {
        placeholder.classList.toggle("hidden", Boolean(selectedValue));
      }

      fields.forEach((field) => {
        if (!(field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement || field instanceof HTMLSelectElement)) {
          return;
        }

        const isActive = field.dataset.serviceField === selectedValue;
        field.disabled = !isActive;
        field.required = isActive;
      });
    };

    serviceSelect?.addEventListener("change", updateServicePanel);
    updateServicePanel();
  }
</script>
