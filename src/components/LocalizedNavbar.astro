---
import { uiContent } from "@/data/ui-content";
import {
  getLocalizedPath,
  localeLabels,
  locales,
  routeLabels,
  serviceRouteKeys,
  type Locale,
  type RouteKey,
} from "@/lib/routes";

interface Props {
  locale: Locale;
  routeKey: RouteKey;
}

const { locale, routeKey } = Astro.props;
const ui = uiContent[locale];
const homePath = getLocalizedPath(locale, "home");
const localeLinks = locales.map((item) => ({
  locale: item,
  label: localeLabels[item],
  href: getLocalizedPath(item, routeKey),
}));
---

<nav class="fixed left-0 right-0 top-0 z-50 border-b border-border bg-card/90 backdrop-blur-md" data-nav-root>
  <div class="container-narrow flex h-16 items-center justify-between px-4 md:px-8">
    <a href={homePath} class="text-lg font-bold tracking-tight text-primary sm:text-xl">SERVIDRONE</a>

    <div class="hidden items-center gap-6 md:flex">
      <a href={homePath} class="text-sm font-medium text-muted-foreground transition-colors hover:text-primary">
        {routeLabels.home[locale]}
      </a>
      {
        serviceRouteKeys.map((serviceKey) => (
          <a
            href={getLocalizedPath(locale, serviceKey)}
            class={`text-sm font-medium transition-colors hover:text-primary ${
              routeKey === serviceKey ? "text-primary" : "text-muted-foreground"
            }`}
          >
            {routeLabels[serviceKey][locale]}
          </a>
        ))
      }
      <a href="#faq" class="text-sm font-medium text-muted-foreground transition-colors hover:text-primary">
        {ui.navFaq}
      </a>
      <a href="#contact" class="btn btn-primary px-4 py-2 text-sm">
        {ui.navContact}
      </a>
      <div class="flex items-center rounded-full border border-border bg-background px-3 py-1">
        {
          localeLinks.map((link, index) => (
            <span class="flex items-center">
              {index > 0 && <span aria-hidden="true" class="px-2 text-muted-foreground/60">|</span>}
              <a
                href={link.href}
                class={`text-xs font-semibold transition-colors hover:text-primary ${
                  link.locale === locale ? "text-primary" : "text-muted-foreground"
                }`}
              >
                {link.label}
              </a>
            </span>
          ))
        }
      </div>
    </div>

    <button
      type="button"
      class="inline-flex text-foreground md:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Toggle navigation"
      data-nav-toggle
    >
      <svg aria-hidden="true" viewBox="0 0 24 24" class="h-6 w-6" data-nav-icon="open" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg aria-hidden="true" viewBox="0 0 24 24" class="hidden h-6 w-6" data-nav-icon="close" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 6l12 12M18 6L6 18"></path>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden max-h-[calc(100svh-4rem)] overflow-y-auto border-b border-border bg-card px-4 pb-5 md:hidden" data-nav-menu>
    <a href={homePath} class="block py-2 text-sm font-medium text-muted-foreground" data-nav-link>
      {routeLabels.home[locale]}
    </a>
    {
      serviceRouteKeys.map((serviceKey) => (
        <a href={getLocalizedPath(locale, serviceKey)} class="block py-2 text-sm font-medium text-muted-foreground" data-nav-link>
          {routeLabels[serviceKey][locale]}
        </a>
      ))
    }
    <a href="#faq" class="block py-2 text-sm font-medium text-muted-foreground" data-nav-link>
      {ui.navFaq}
    </a>
    <a href="#contact" class="btn btn-primary mt-2 w-full" data-nav-link>
      {ui.navContact}
    </a>
    <div class="mt-4 flex flex-wrap items-center gap-y-2 border-t border-border pt-4">
      {
        localeLinks.map((link, index) => (
          <span class="flex items-center">
            {index > 0 && <span aria-hidden="true" class="px-2 text-muted-foreground/60">|</span>}
            <a
              href={link.href}
              class={`text-xs font-semibold ${
                link.locale === locale ? "text-primary" : "text-muted-foreground"
              }`}
            >
              {link.label}
            </a>
          </span>
        ))
      }
    </div>
  </div>
</nav>

<script>
  const nav = document.querySelector("[data-nav-root]");
  if (nav) {
    const toggle = nav.querySelector("[data-nav-toggle]");
    const menu = nav.querySelector("[data-nav-menu]");
    const openIcon = nav.querySelector('[data-nav-icon="open"]');
    const closeIcon = nav.querySelector('[data-nav-icon="close"]');
    const links = nav.querySelectorAll("[data-nav-link]");

    const setOpen = (isOpen) => {
      toggle?.setAttribute("aria-expanded", String(isOpen));
      menu?.classList.toggle("hidden", !isOpen);
      openIcon?.classList.toggle("hidden", isOpen);
      closeIcon?.classList.toggle("hidden", !isOpen);
    };

    toggle?.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      setOpen(!isOpen);
    });

    links.forEach((link) => link.addEventListener("click", () => setOpen(false)));
  }
</script>
